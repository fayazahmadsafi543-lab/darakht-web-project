# Supabase Database
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction" pooler for DATABASE_URL and "Direct" for DIRECT_URL

# Pooled connection (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (port 5432) — used by Prisma migrations & db push
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Darakht Software Solutions"

# Email (Resend) — https://resend.com
# Inquiry emails go to INQUIRY_NOTIFY_EMAIL, or company_email from admin Settings
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="Darakht Software Solutions <onboarding@resend.dev>"
INQUIRY_NOTIFY_EMAIL="info@techvision.com"

# Analytics (set one or both)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"

# Optional: use static demo data when DB is unavailable (set false in production)
USE_DEMO_DATA="false"

# Optional: push notification fallback when Resend is unavailable (use a private topic name)
NTFY_TOPIC="your-private-ntfy-topic"
